GEMINI_API_KEY=여기에_Gemini_API_키_입력
GEMINI_MODEL=gemini-2.0-flash
FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"..."}

# ── 전화번호 SMS 인증 (send-otp / verify-otp) ──────────────────────
# 전화번호 해시용 pepper. 절대 커밋·로그 노출 금지.
#   openssl rand -hex 32
# 주의: 원문 번호를 저장하지 않으므로 이 값을 바꾸면 기존 phone_hash 를
# 재계산할 수 없다(전원 재인증 필요). 교체 시 users.pepper_version 활용.
PHONE_HASH_PEPPER=여기에_openssl_rand_hex_32_결과_입력

# 네이버 클라우드 SENS (SMS 발송)
SENS_SERVICE_ID=ncp:sms:kr:...:서비스명
SENS_ACCESS_KEY=여기에_NCP_액세스_키
SENS_SECRET_KEY=여기에_NCP_시크릿_키
SENS_FROM=01012345678

# OTP 발송 상한 (미설정 시 기본값 사용)
OTP_DAILY_GLOBAL_CAP=2000
OTP_USER_DAILY_CAP=5
